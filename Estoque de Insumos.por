programa {
  funcao inicio() {
    inteiro a, b, soma // tipo da variavel

    //operacao do codigo
    escreva("Digite a quantidade no primeiro estoque: ", a)
    leia(a)

    escreva("Agora digite a quantidade do segundo estoque: ")
    leia(b)

    //soma da quantidade das remessas
    soma = a + b
    escreva("A quantidade disponivel no estoque é: ", soma)


  }
}
